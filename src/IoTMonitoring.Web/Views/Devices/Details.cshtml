@model DeviceViewModel
@{
    ViewData["Title"] = "Detalhes";
}
<h1>Dispositivo</h1>
<dl class="row">
    <dt class="col-sm-2">Nome</dt><dd class="col-sm-10">@Model.Name</dd>
    <dt class="col-sm-2">DeviceId</dt><dd class="col-sm-10">@Model.DeviceId</dd>
    <dt class="col-sm-2">Status</dt><dd class="col-sm-10">@Model.Status</dd>
    <dt class="col-sm-2">Localização</dt><dd class="col-sm-10">@Model.Location</dd>
</dl>
<a class="btn btn-secondary" asp-action="Index">Voltar</a>
