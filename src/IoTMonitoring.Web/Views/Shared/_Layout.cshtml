<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - IoT Monitoring</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">IoT Monitoring</a>
                <div class="collapse navbar-collapse show">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Dashboard</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Devices" asp-action="Index">Dispositivos</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="SensorData" asp-action="Index">Sensores</a></li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="container mt-4">
        @if (TempData["SuccessMessage"] is string success)
        {
            <div class="alert alert-success">@success</div>
        }
        @if (TempData["ErrorMessage"] is string error)
        {
            <div class="alert alert-danger">@error</div>
        }
        @RenderBody()
    </main>

    <footer class="border-top footer text-muted mt-4 py-3">
        <div class="container">
            IoT Monitoring - ASP.NET Core MVC
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
