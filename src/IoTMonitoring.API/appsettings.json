{
  "ConnectionStrings": {
    "DefaultConnection": "User Id=RM560380;Password=140705;Data Source=oracle.fiap.com.br:1521/orcl;"
  },
  "MongoDb": {
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "IoTMonitoringDb",
    "AlertsCollectionName": "SensorAlerts"
  },
  "Jwt": {
    "Key": "IoTMonitoring_SuperSecretKey_2024_MinLength32chars!!",
    "Issuer": "IoTMonitoring.API",
    "Audience": "IoTMonitoring.Client",
    "ExpirationHours": "24"
  },
  "Users": [
    { "Username": "admin", "Password": "admin123", "Role": "Admin" },
    { "Username": "user",  "Password": "user123",  "Role": "User"  }
  ],
  "HealthChecks": {
    "ExternalServiceUrl": "https://www.microsoft.com"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "AllowedHosts": "*"
}
